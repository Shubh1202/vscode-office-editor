{
  "name": "office-editor",
  "displayName": "Office Editor (Docx, Xlsx)",
  "description": "Powerful, fast, and secure editor for Word (.docx) and Excel (.xlsx) files directly inside VS Code.",
  "version": "1.0.1",
  "icon": "icon.png",
  "license": "MIT",
  "publisher": "shubhamprajapati1202",
  "repository": {
    "type": "git",
    "url": "https://github.com/Shubh1202/vscode-office-editor"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "office",
    "excel",
    "word",
    "docx",
    "xlsx",
    "spreadsheet",
    "csv",
    "editor",
    "preview",
    "productivity"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "docxxlsx.docxEditor",
        "displayName": "Word Document Editor",
        "selector": [
          {
            "filenamePattern": "*.docx"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "docxxlsx.xlsxEditor",
        "displayName": "Excel Spreadsheet Editor",
        "selector": [
          {
            "filenamePattern": "*.xlsx"
          }
        ],
        "priority": "default"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js",
    "test:unit": "mocha out/test/unit/**/*.test.js"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "16.x",
    "@types/quill": "^2.0.10",
    "@types/dompurify": "^3.0.0",
    "@types/jsdom": "^21.1.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "eslint": "^8.28.0",
    "typescript": "^4.9.4",
    "webpack": "^5.75.0",
    "webpack-cli": "^5.0.1",
    "ts-loader": "^9.4.2",
    "css-loader": "^6.7.3",
    "style-loader": "^3.3.1",
    "copy-webpack-plugin": "^11.0.0",
    "glob": "^8.0.3",
    "mocha": "^10.2.0",
    "chai": "^4.3.7",
    "@types/mocha": "^10.0.1",
    "@types/chai": "^4.3.4"
  },
  "dependencies": {
    "mammoth": "^1.5.1",
    "html-to-docx": "^1.8.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.19.3/xlsx-0.19.3.tgz",
    "quill": "^1.3.7",
    "tabulator-tables": "^5.4.4",
    "dompurify": "^3.0.1",
    "jsdom": "^21.1.1"
  }
}
